#include <iostream>
#include <vector>
#include <string>
using namespace std;

struct Student {
    int id;
    string name;
    int age;
    double grade;
};

int main() {
    vector<Student> students;
    int n;

    cout << "Сколько студентов? ";
    cin >> n;

    for (int i = 0; i < n; i++) {
        Student s;
        s.id = i + 1;
        cout << "\nСтудент " << i + 1 << ":\n";
        cout << "Имя: ";    cin >> s.name;
        cout << "Возраст: "; cin >> s.age;
        cout << "Балл: ";   cin >> s.grade;
        students.push_back(s);
    }

    cout << "\nСписок студентов:\n";
    for (const auto& s : students) {
        cout << "ID: "            << s.id
             << ", Имя: "         << s.name
             << ", Возраст: "     << s.age
             << ", Средний балл: "<< s.grade
             << endl;
    }

    return 0;
}
